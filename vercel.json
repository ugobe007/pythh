{
  "installCommand": "echo skip",
  "buildCommand": "echo skip",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.pythh.ai" }],
      "destination": "https://pythh.ai/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "https://hot-honey.fly.dev/"
    },
    {
      "source": "/:path*",
      "destination": "https://hot-honey.fly.dev/:path*"
    }
  ]
}
