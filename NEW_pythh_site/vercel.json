{
  "installCommand": "echo skip",
  "buildCommand": "mkdir -p dist && echo '<!doctype html><title>pythh fly proxy</title>' > dist/index.html",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "https://hot-honey.fly.dev/$1"
    }
  ]
}
