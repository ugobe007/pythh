{
  "installCommand": "echo skip",
  "buildCommand": "mkdir -p dist && rm -f dist/index.html",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "https://hot-honey.fly.dev/"
    },
    {
      "source": "/:path*",
      "destination": "https://hot-honey.fly.dev/:path*"
    }
  ]
}
