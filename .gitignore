# Environment variables (NEVER commit these!)
.env
.env.local
.env.*.local
*.env

# Backup env files — includes timestamped variants like .env.backup.20260108_172333
.env.bak*
.env.backup
.env.backup.*
.env.save
*.env.backup.*
.env.*.backup.*

# Reports directory (if it doesn't already exist)
reports/
*.log

