# Server Configuration
PORT=3002
NODE_ENV=development

# Supabase Configuration (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Signal Art — Google AI Studio raster generation
GEMINI_API_KEY=your_aistudio_api_key
# AISTUDIO_API_KEY=alias for GEMINI_API_KEY
# SIGNAL_ART_IMAGE_MODEL=gemini-2.5-flash-image
# SIGNAL_ART_RASTER=0  # set to skip raster (SVG only)
# SIGNAL_ART_STORAGE_BUCKET=pythh-art
