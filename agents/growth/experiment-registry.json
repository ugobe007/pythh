{
  "version": 1,
  "updated_at": "2026-06-24T23:35:00Z",
  "experiments": [
    {
      "id": "founder_preview_signal_delta_gate",
      "audience": "founder",
      "name": "Preview cliffhanger × signal-delta gate",
      "status": "running",
      "parent_experiment": "founder_hero_entry",
      "applies_when": "variant_key=matches_preview",
      "hypothesis": "A locked signal-delta teaser on the action_gate (matches shifted thesis-fit this week) converts more previewers to signup than utility-only gates (save/intro/export), and seeds a return trigger.",
      "loops": ["preview_cliffhanger", "signal_delta"],
      "variants": [
        {
          "key": "delta_cliffhanger",
          "traffic_pct": 100,
          "schema": {
            "gate_addon": "signal_delta_card",
            "requires_real_god_history": true,
            "fields_shown": ["moved_toward_count", "moved_away_count", "match_count"]
          },
          "copy": {
            "picky": "We screened {match_count} investors; {moved_toward_count} changed thesis-fit toward you this week and {moved_away_count} cooled.",
            "headline": "Your matches moved this week.",
            "cta": "See which moved — create a free account",
            "footer": "Free account unlocks the full delta, the why, and the warm intro before the window closes."
          },
          "guardrails": {
            "no_fabricated_deltas": true,
            "source": "god_score_history"
          }
        }
      ],
      "metrics": {
        "primary": "founder_signup_started",
        "secondary": ["preview_delta_teaser_viewed", "founder_signup_completed", "return_visit_7d"]
      },
      "promotion_note": "Running 2026-06-24 — preview_delta_teaser_viewed wired; real deltas only (null when no movement)."
    },
    {
      "id": "founder_hero_entry",
      "audience": "founder",
      "name": "Founder hero entry",
      "status": "running",
      "hypothesis": "URL-first hero converts better than email-first for founders who already have a site.",
      "variants": [
        {
          "key": "url_first",
          "traffic_pct": 10,
          "schema": {
            "entry": "url",
            "steps": ["url", "activate", "matches"],
            "signup_path": "/activate",
            "fields_required": ["startup_url"]
          },
          "copy": {
            "headline": "Find investors that match your thesis.",
            "cta": "Submit your startup URL",
            "subline": "Pythh reads your site and maps investors in ~20 seconds."
          }
        },
        {
          "key": "matches_preview",
          "traffic_pct": 90,
          "schema": {
            "entry": "url_with_preview",
            "steps": ["url", "instant_matches", "action_gate"],
            "signup_path": "/activate",
            "fields_required": ["startup_url"],
            "gate_actions": ["save", "intro", "export"]
          },
          "copy": {
            "headline": "See your investor matches before you sign up.",
            "cta": "Preview matches",
            "subline": "URL → live match preview → account to save intros."
          }
        }
      ],
      "metrics": {
        "primary": "founder_signup_completed",
        "secondary": ["url_submitted", "instant_matches_viewed", "checkout_started"]
      }
    },
    {
      "id": "founder_preview_gate_cta",
      "audience": "founder",
      "name": "Preview gate CTA copy",
      "status": "running",
      "hypothesis": "Benefit-led gate CTAs convert better than neutral action labels after the free shortlist reveal.",
      "parent_experiment": "founder_hero_entry",
