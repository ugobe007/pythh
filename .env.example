# Pythh — public URLs (production: https://pythh.ai). Used by emails, link builders, health scripts.
# Also used by the API server (server/index.js) to allow browser CORS from these origins when the SPA
# is on Vercel and the API is on Fly.io.
APP_URL=https://pythh.ai
APP_BASE_URL=https://pythh.ai

# Optional: comma-separated extra allowed CORS origins (production API on Fly). Use when you add a
# Vercel preview URL or a new custom domain before it is hardcoded in ALLOWED_ORIGINS.
# Example: CORS_EXTRA_ORIGINS=https://my-app.vercel.app,https://staging.example.com
# CORS_EXTRA_ORIGINS=

# API Configuration (browser → Node). Production builds: set to your public API origin (e.g. https://api.example.com).
# Dev: if you omit VITE_API_URL, the app defaults to http://localhost:3002 (see src/lib/apiConfig.ts).
VITE_API_URL=http://localhost:3002
VITE_BACKEND_URL=http://localhost:3002

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Key (REQUIRED for scrapers - bypasses RLS)
# Get from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# For scraper scripts that don't use VITE_ prefix
SUPABASE_URL=https://your-project.supabase.co

# OpenAI (Required for AI startup discovery)
OPENAI_API_KEY=sk-your-openai-key
VITE_OPENAI_API_KEY=sk-your-openai-key

# ── Postgres (optional — only for raw SQL scripts: dq:runbook, psql, pg) ──────
# This is NOT the anon key or service_role JWT. It is the database user password.
# Supabase: Settings → Database → Database password (reset copies a NEW connection string).
# Paste the full "URI" they show (pooler :6543 session mode is fine). ?sslmode=require is fine.
# If the password has @ : / ? # characters, use the string Supabase provides as-is.
# Fly: fly secrets set DATABASE_URL='postgresql://...'  (single quotes help in shell)
DATABASE_URL=

# SSOT RSS scraper (scripts/core/ssot-rss-scraper.js): graph-join detail lines (name lookup, sanitize).
# Default: sample all feeds (~8% per line); Google News / VC News Daily use half that. RSS_SCRAPER_DEBUG=1 or RSS_NAME_LOOKUP_LOG=full = log all.
# RSS_NAME_LOOKUP_LOG=off silences those lines. Optional: RSS_NAME_LOOKUP_SAMPLE_RATE=0.08
# frameParser EventID [DEBUG] lines: off by default. Set RSS_LOG_EVENT_IDS=1 (or RSS_SCRAPER_DEBUG=1) for sampled logs; optional RSS_EVENT_ID_LOG_RATE=0.05
# dq:runbook rewrites Supabase URLs to sslmode=no-verify (pg merges URL ssl over Pool.ssl;
# require becomes strict verify and can hit SELF_SIGNED_CERT_IN_CHAIN on the pooler).
# Set DATABASE_SSL=false to skip that rewrite. DATABASE_SSL=true forces no-verify for any host.
